---
import background2 from '../assets/background2.png';
---

<header class="header">
    <nav class="navbar">
        <div class="logo">🎬 CINESTREAM</div>
        <div class="nav-right">
            <label class="toggle-wrapper" title="Modo oscuro">
                <input type="checkbox" id="modoOscuro" class="toggle-input">
                <span class="toggle-track">
                    <span class="toggle-thumb"></span>
                </span>
                <span class="toggle-label">Modo oscuro</span>
            </label>
        </div>
    </nav>

    <div class="hero">
        <img id="background" src={background2.src} alt="" fetchpriority="high" />
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <p class="hero-tag">✦ PLATAFORMA DE STREAMING</p>
            <h1>Tu cine,<br/><span class="accent">cuando quieras.</span></h1>
            <p class="hero-sub">Explorá miles de películas y series. Guardá tus favoritas y descubrí nuevos géneros.</p>
        </div>
    </div>
</header>

<style>
    * { margin: 0; box-sizing: border-box; }

    .header {
        flex-shrink: 0;
        position: relative;
    }

    /* ── Navbar ── */
    .navbar {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 100;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px 48px;
        background: linear-gradient(to bottom, rgba(0,0,0,0.85) 0%, transparent 100%);
        transition: background 0.3s;
    }

    .logo {
        font-family: 'Bebas Neue', 'Impact', sans-serif;
        font-size: 28px;
        letter-spacing: 4px;
        color: #e50914;
        text-shadow: 0 0 30px rgba(229,9,20,0.5);
        cursor: default;
        user-select: none;
    }

    .nav-right {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    /* ── Toggle switch ── */
    .toggle-wrapper {
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
    }
    .toggle-input { display: none; }
    .toggle-track {
        width: 42px;
        height: 22px;
        background: #444;
        border-radius: 999px;
        position: relative;
        transition: background 0.3s;
    }
    .toggle-input:checked ~ .toggle-track { background: #e50914; }
    .toggle-thumb {
        position: absolute;
        top: 3px; left: 3px;
        width: 16px; height: 16px;
        background: white;
        border-radius: 50%;
        transition: left 0.3s;
        box-shadow: 0 1px 4px rgba(0,0,0,0.4);
    }
    .toggle-input:checked ~ .toggle-track .toggle-thumb { left: 23px; }
    .toggle-label {
        font-size: 12px;
        color: #ccc;
        white-space: nowrap;
        letter-spacing: 0.5px;
    }

    /* ── Hero ── */
    .hero {
        position: relative;
        height: 56vh;
        min-height: 340px;
        overflow: hidden;
        display: flex;
        align-items: flex-end;
    }

    #background {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: brightness(0.55) saturate(1.1);
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to bottom,
            rgba(0,0,0,0.1) 0%,
            rgba(0,0,0,0.0) 30%,
            rgba(20,20,20,0.7) 70%,
            var(--catalogo, #141414) 100%
        );
    }

    .hero-content {
        position: relative;
        z-index: 2;
        padding: 0 60px 48px;
        max-width: 640px;
    }

    .hero-tag {
        font-size: 11px;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: #e50914;
        margin-bottom: 14px;
        font-weight: 600;
    }

    h1 {
        font-family: 'Bebas Neue', 'Impact', sans-serif;
        font-size: clamp(48px, 6vw, 80px);
        line-height: 1;
        color: #fff;
        letter-spacing: 2px;
        text-shadow: 0 4px 24px rgba(0,0,0,0.6);
        margin-bottom: 16px;
    }

    .accent { color: #e50914; }

    .hero-sub {
        font-size: 15px;
        line-height: 1.6;
        color: rgba(255,255,255,0.75);
        max-width: 460px;
    }
</style>