---
import astroLogo from '../assets/astro.svg';
import background2 from '../assets/background2.png';
---

	<header class="header">
		<img id="background" src={background2.src} alt="" fetchpriority="high" />
		<h1>Bienvenido</h1>
		<h3>Aquí encontrarás todas las películas que necesitas</h3>
		<div class="OscEd">
			
		</div>
	</header>

<style>
	*{
		margin: 0;}
	.header{
		flex: 1;
		height: 25vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
	}
	.header h1{
		font-family: 'Oswald', sans-serif;
		font-size: 50px;
		letter-spacing: 2px
	}
	#background {
		position: fixed;
		top: 0;
		right: 0;
		width: 100%;
		height: 25%;
		z-index: -1;
		opacity: 0.5;
		filter: blur(3px);
	}

</style>
