---
import astroLogo from '../assets/astro.svg';
import background from '../assets/background.svg';
---

<div id="container">
	<img id="background" src={background.src} alt="" fetchpriority="high" />
	<aside class="preferencias">
		<header></header>
	</aside>
	<main>
		<header class="header">
			<h1>Bienvenido al catálogo de películas</h1>
		</header>
	</main>
</div>

<style>
	*{
		margin: 0;
		padding: 0;
	}
	.preferencias{
		height: 100vh;
		background-color: #282828;
		width: 40%;
	}
	.preferencias header{
		width: 100%;
		height: 10%;
		border-bottom-color: #808080;
		border-bottom-width: 100px;
	}
	.header{
		width: 100%;
		height: 20vh;
		display: flex;
		justify-content: center;
		align-items: center;
	}
	.header h1{
		font-family: 'Oswald', sans-serif;
		font-size: 50px;
		letter-spacing: 2px
	}
	#background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		filter: blur(100px);
	}

</style>
