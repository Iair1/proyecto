---
import astroLogo from '../assets/astro.svg';
import background2 from '../assets/background2.png';
---

	<header class="header">
		<div class="OscEd">
			<input type="checkbox" id="modoOscuro"> <p>Modo oscuro</p>
		</div>
		<img id="background" src={background2.src} alt="" fetchpriority="high" />
		<h1>Bienvenido</h1>
		<h3>Aquí encontrarás todas las películas que necesitas</h3>
	</header>

<style>
	*{
		margin: 0;
	}
	.header{
		flex-shrink: 0;
		height: 30vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
	}
	.header h1{
		font-family: 'Oswald', sans-serif;
		font-size: 50px;
		letter-spacing: 2px
	}
	#background {
		position: fixed;
		top: 0;
		right: 0;
		width: 100%;
		height: 33%;
		z-index: -1;
		opacity: 0.5;
		filter: blur(3px);
	}
	.OscEd{
		width: 110px;
		aspect-ratio: 16/5;
		background-color: #282828;
		position: absolute;
		top: 0;
		right: 0;
		border-bottom-left-radius: 9999px;
		display: flex;
		justify-content: center;
		align-items: center;
	}
	.OscEd p {
		font-size: small;
		white-space: nowrap;
		color: white;
	}
</style>
